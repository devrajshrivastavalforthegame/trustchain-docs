VITE_API_BASE_URL=http://localhost:5000/api
VITE_PUBLIC_APP_URL=http://localhost:5173
VITE_ENABLE_DEMO_FALLBACK=false
VITE_POLLING_INTERVAL_MS=5000
VITE_MAX_UPLOAD_MB=10

# Frontend API wrapper encryption. Must match server API_WRAPPER_KEY.
# Generate with: cd server && npm run keys
VITE_API_WRAPPER_ENCRYPTION=true
VITE_API_WRAPPER_KEY=replace-with-same-32-byte-base64-key-as-server
