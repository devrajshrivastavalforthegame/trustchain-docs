PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
ALLOW_INSECURE_DEMO_KEYS=false

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=trustchain

JWT_SECRET=replace-with-strong-secret-from-npm-run-keys
JWT_EXPIRY=15m

# Generate keys with: cd server && npm run keys
ENCRYPTION_MASTER_KEY=replace-with-32-byte-base64-key
ENCRYPTION_KEY_ID=local-key-v1
LOOKUP_HASH_SECRET=replace-with-long-random-lookup-secret

# API wrapper encryption. Use same value in client/.env as VITE_API_WRAPPER_KEY.
API_WRAPPER_KEY=replace-with-32-byte-base64-key
API_RESPONSE_ENCRYPTION=false

MAX_UPLOAD_MB=10

# Google Drive is optional. Local encrypted storage is used when false.
GOOGLE_DRIVE_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=C:/absolute/path/to/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=optional-drive-folder-id
GOOGLE_DRIVE_LINK_EXPIRES_MINUTES=15
GCS_ENABLED=false

# Blockchain / EVM
BLOCKCHAIN_NETWORK=hardhat-local
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_PRIVATE_KEY=replace-with-local-or-amoy-private-key
CONTRACT_ADDRESS=replace-after-deploy

# AI integration
USE_AI=true
AI_SERVICE_URL=http://localhost:8001
AI_TIMEOUT_MS=20000
USE_OLLAMA=true
OLLAMA_MODEL=llama3.2:1b
OLLAMA_URL=http://localhost:11434/api/generate


# TrustChain Safe Combined Security Patch
ENABLE_RBAC=false
API_RESPONSE_ENCRYPTION=false
ENABLE_RATE_LIMIT=true
ENABLE_SECURE_CORS=true
ENABLE_CRYPTO_HASH=true

# JWT access token demo setting
ACCESS_TOKEN_EXPIRY=15m

# CORS configuration
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Rate limit overrides; increase for demo if needed
RATE_LIMIT_GENERAL_MAX=600
RATE_LIMIT_AUTH_MAX=200
RATE_LIMIT_UPLOAD_MAX=100
RATE_LIMIT_VERIFICATION_MAX=200
RATE_LIMIT_AI_MAX=100

# Optional document HMAC signing
DOCUMENT_HMAC_SECRET=replace-with-long-random-secret

# Optional API encryption wrapper; keep false unless frontend decrypt is implemented
API_WRAPPER_KEY=replace-with-32-byte-base64-or-64-hex-key

